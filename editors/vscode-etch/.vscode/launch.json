{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/test/suite/index.cjs"
      ],
      "outFiles": [
        "${workspaceFolder}/out/test/**/*.cjs"
      ],
      "preLaunchTask": "pnpm: compile"
    }
  ]
}
