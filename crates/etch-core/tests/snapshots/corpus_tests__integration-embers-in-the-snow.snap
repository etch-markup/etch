                "type": "Paragraph",
                "content": [
                  {
                    "type": "Emphasis",
                    "content": [
                      {
                        "type": "Text",
                        "value": "\"I'll come back when the embers remember how to burn.\""
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Paragraph",
                "content": [
                  {
                    "type": "Text",
                    "value": "— Kael's last letter"
                  }
                ],
                "attrs": {
                  "classes": [
                    "attribution"
                  ]
                }
              }
            ]
          },
          {
            "type": "Paragraph",
            "content": [
              {
                "type": "Text",
                "value": "She tucked it into her coat and walked into the white."
              }
            ]
          }
        ],
