        "body": [
          {
            "type": "Paragraph",
            "content": [
              {
                "type": "Text",
                "value": "The village woke to silence. Not the silence of sleep,"
              },
              {
                "type": "SoftBreak"
              },
              {
                "type": "Text",
                "value": "but the silence of snow — heavy, patient, "
              },
              {
                "type": "Highlight",
                "content": [
                  {
                    "type": "Text",
                    "value": "absolute"
                  }
                ]
              },
              {
                "type": "Text",
                "value": "."
              }
            ]
          },
          {
            "type": "BlockDirective",
            "name": "aside",
            "body": [
              {
                "type": "Paragraph",
                "content": [
                  {
                    "type": "Text",
                    "value": "The author grew up in a town like this one."
                  }
                ]
              }
            ]
          },
          {
            "type": "Paragraph",
            "content": [
              {
                "type": "InlineDirective",
                "name": "character",
                "content": [
                  {
                    "type": "Text",
                    "value": "Mira"
                  }
                ],
                "attrs": {
                  "pairs": {
                    "species": "wolf"
                  }
                }
              },
              {
                "type": "Text",
                "value": " stepped onto the porch,"
              },
              {
                "type": "SoftBreak"
              },
              {
                "type": "Text",
                "value": "breath curling like smoke. She held a letter — creased"
              },
              {
                "type": "SoftBreak"
              },
              {
                "type": "Text",
                "value": "from folding and refolding — and read it one last time."
              }
            ]
          },
          {
