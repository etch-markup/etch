          }
        },
        "body": [
          {
            "type": "Paragraph",
            "content": [
              {
                "type": "Text",
                "value": "Three days later, she found what she was looking for."
              },
              {
                "type": "FootnoteReference",
                "label": "1"
              }
            ]
          },
          {
            "type": "Paragraph",
            "content": [
              {
                "type": "Text",
                "value": "Not Kael — not exactly. But the place where he'd been,"
              },
              {
                "type": "SoftBreak"
              },
              {
                "type": "Text",
                "value": "marked by a ring of stones and the ash of a fire"
              },
              {
                "type": "SoftBreak"
              },
              {
                "type": "Text",
                "value": "that might have been warm "
              },
              {
                "type": "Highlight",
                "content": [
                  {
                    "type": "Text",
                    "value": "yesterday"
                  }
                ]
              },
              {
                "type": "Text",
                "value": "."
              }
            ]
          },
          {
            "type": "Paragraph",
            "content": [
              {
                "type": "Text",
                "value": "The area measured roughly "
              },
              {
                "type": "InlineDirective",
                "name": "math",
                "content": [
                  {
                    "type": "Text",
                    "value": "3\\text{m} \\times 3\\text{m}"
                  }
                ]
              },
              {
                "type": "Text",
                "value": ","
              },
              {
                "type": "SoftBreak"
              },
              {
                "type": "Text",
                "value": "with the stones arranged in a precise circle."
              }
            ]
          },
          {
            "type": "Paragraph",
            "content": [
              {
                "type": "Text",
                "value": "Her address was simple:"
              },
